{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "values": false } },
      "title": "Service Up",
      "type": "stat",
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 0 },
      "id": 2,
      "title": "Request Rate (1m)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(http_requests_total[1m])", "legendFormat": "{{job}}" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 3,
      "title": "Average Latency",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m])", "legendFormat": "{{job}}" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 4,
      "title": "HTTP Errors (4xx/5xx)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (status) (rate(http_requests_total{status=~'[45]..'}[1m]))", "legendFormat": "{{status}}" }
      ]
    }
  ],
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["microservices"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Microservices Observability",
  "uid": "microservices-dashboard",
