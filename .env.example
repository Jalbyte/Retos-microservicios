# ============================================================
# .env.example — Variables de entorno del proyecto (Reto 4)
# Copiar a .env y ajustar para ejecución local sin Docker
# ============================================================

# ─── JWT (misma clave en TODOS los servicios) ────────────────
# ADVERTENCIA: Solo para uso académico. En producción usar RS256
JWT_SECRET=super_secret_reto4_jwt_key_2024

# ─── auth-service (Reto 4) ───────────────────────────────────
AUTH_PORT=3001
AUTH_DATABASE_URL=postgres://postgres:postgres@localhost:5436/auth_db
AUTH_RABBITMQ_URL=amqp://admin:admin@localhost:5672
AUTH_RABBITMQ_EXCHANGE=empleados_exchange
AUTH_EXCHANGE=auth_exchange

# ─── gestion-empleados (Reto 1) ──────────────────────────────
EMPLEADOS_PORT=8080
EMPLEADOS_DATABASE_URL=postgresql://camilo:camilo@localhost:5433/empleados_db
DEPARTAMENTOS_URL=http://localhost:8081

# ─── gestion-departamentos (Reto 2) ──────────────────────────
DEPARTAMENTOS_PORT=8081
DEPARTAMENTOS_DATABASE_URL=postgresql://camilo:camilo@localhost:5434/departamentos_db

# ─── servicio-notificaciones (Reto 3) ────────────────────────
NOTIFICACIONES_PORT=8084
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=notifications
RABBITMQ_EXCHANGE=empleados_exchange

# ─── gestion-perfiles (Reto 3) ───────────────────────────────
PERFILES_PORT=8085
PERFILES_DB_HOST=localhost
PERFILES_DB_PORT=5435
PERFILES_DB_NAME=perfiles_db
PERFILES_DB_USER=camilo
PERFILES_DB_PASSWORD=camilo

# ─── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_URL=amqp://admin:admin@localhost:5672
