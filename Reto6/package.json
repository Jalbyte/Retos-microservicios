{
  "name": "reto6-express-service",
  "version": "1.0.0",
  "description": "Microservicio Express para CI/CD del Reto 6",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test:unit": "jest --coverage --runInBand",
    "test:e2e": "cucumber-js",
    "test:e2e:remote": "TEST_BASE_URL=http://localhost:8086 cucumber-js",
    "test": "npm run test:unit"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.43.0",
    "@opentelemetry/exporter-zipkin": "^1.22.0",
    "@opentelemetry/sdk-node": "^0.49.1",
    "express": "^4.21.2",
    "prom-client": "^15.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "axios": "^1.8.4",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^7.1.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "app.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text-summary"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "branches": 60,
        "functions": 70,
        "statements": 70
      }
    },
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "reports/junit",
          "outputName": "unit-tests.xml"
        }
      ]
    ]
  }
}
