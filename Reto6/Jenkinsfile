pipeline {
  agent any

  environment {
    IMAGE_NAME = 'reto6-express-service'
    SONAR_HOST_URL = "${env.SONAR_HOST_URL ?: 'http://sonarqube:9000'}"
    JENKINS_CONTAINER = 'retos-microservicios-jenkins-1'
  }

  options {
    skipDefaultCheckout(true)
    disableConcurrentBuilds()
  }

  triggers {
    githubPush()
    pollSCM('* * * * *')
  }

  stages {
    stage('Docker Preflight') {
      steps {
        sh 'docker --version'
        sh 'docker ps'
      }
    }

    stage('Checkout') {
      steps {
        deleteDir()
        checkout scm
      }
    }

    stage('Build') {
      steps {
        sh '''
          docker run --rm \
            --volumes-from $JENKINS_CONTAINER \
            -w "$WORKSPACE/Reto6" \
            node:20-slim sh -lc "[ -f package-lock.json ] || npm install --package-lock-only; npm ci"
        '''
      }
    }

    stage('Test') {
      steps {
        sh '''
          docker run --rm \
            --volumes-from $JENKINS_CONTAINER \
            -w "$WORKSPACE/Reto6" \
            node:20-slim sh -c "npm run test:unit"
        '''
      }
      post {
        always {
          junit testResults: 'Reto6/reports/junit/*.xml', allowEmptyResults: true
          archiveArtifacts artifacts: 'Reto6/coverage/lcov.info', fingerprint: true
        }
      }
    }

    stage('SonarQube') {
      steps {
        withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
          sh '''
            docker run --rm \
              -u root \
              --network retos-microservicios_microservices-network \
              --volumes-from $JENKINS_CONTAINER \
              -e SONAR_HOST_URL=$SONAR_HOST_URL \
              -e SONAR_TOKEN=$SONAR_TOKEN \
              -w "$WORKSPACE/Reto6" \
              sonarsource/sonar-scanner-cli:latest \
              sonar-scanner \
                -Dsonar.projectKey=reto6-express-service \
                -Dsonar.projectName="Reto 6 Express Service" \
                -Dsonar.sources=. \
                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                -Dsonar.host.url=$SONAR_HOST_URL \
                -Dsonar.token=$SONAR_TOKEN \
                -Dsonar.working.directory=.scannerwork
          '''
        }
      }
    }

    stage('Quality Gate') {
      steps {
        withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
          dir('Reto6') {
            sh '''
              set -e
              # Polling for background task completion
              CE_TASK_URL=$(grep ceTaskUrl .scannerwork/report-task.txt | cut -d= -f2-)
              echo "Checking task status at $CE_TASK_URL"
              
              for i in $(seq 1 30); do
                TASK_RESPONSE=$(curl -s -u "$SONAR_TOKEN:" "$CE_TASK_URL")
                STATUS=$(echo "$TASK_RESPONSE" | jq -r '.task.status')
                echo "Task status: $STATUS"
                
                if [ "$STATUS" = "SUCCESS" ]; then
                  ANALYSIS_ID=$(echo "$TASK_RESPONSE" | jq -r '.task.analysisId')
                  break
                fi
                if [ "$STATUS" = "FAILED" ]; then
                  echo "SonarQube analysis failed"
                  exit 1
                fi
                sleep 5
              done

              if [ -z "$ANALYSIS_ID" ]; then
                echo "Timeout waiting for SonarQube analysis"
                exit 1
              fi

              QG_STATUS=$(curl -s -u "$SONAR_TOKEN:" "$SONAR_HOST_URL/api/qualitygates/project_status?analysisId=$ANALYSIS_ID" | jq -r '.projectStatus.status')
              echo "Quality Gate status: $QG_STATUS"
              
              if [ "$QG_STATUS" != "OK" ]; then
                echo "Quality Gate failed: $QG_STATUS"
                exit 1
              fi
            '''
          }
        }
      }
    }

    stage('Package') {
      steps {
        dir('Reto6') {
          sh '''
            docker build -t $IMAGE_NAME:$BUILD_NUMBER -t $IMAGE_NAME:latest .
          '''
        }
      }
    }

    stage('E2E Tests') {
      steps {
        sh '''
          set -e
          INFRA="database-empleados database-departamentos notification-db perfiles-db db-auth rabbitmq"
          SERVICES="auth-service perfiles-service notificaciones-service departamentos-service empleados-service api-gateway"
          
          export DB_EMP_PORT=0 DB_DEP_PORT=0 DB_NOT_PORT=0 DB_PER_PORT=0 DB_AUTH_PORT=0
          export EMP_SVC_PORT=0 DEP_SVC_PORT=0 NOT_SVC_PORT=0 PER_SVC_PORT=0 AUTH_SVC_PORT=0
          export GATEWAY_PORT=0 RETO6_PORT=0 RABBIT_PORT=0 RABBIT_MGMT_PORT=0
          export SONAR_PORT=0 JENKINS_PORT=0 JENKINS_AGENT_PORT=0

          echo "Limpando entorno de pruebas..."
          docker-compose stop $SERVICES $INFRA || true
          docker-compose rm -f $SERVICES $INFRA || true
          
          echo "1. Levantando infraestructura (DBs y Mensajería)..."
          docker-compose up -d $INFRA
          sleep 20

          echo "2. Levantando Microservicios..."
          docker-compose up -d $SERVICES
          
          echo "3. Verificando disponibilidad del sistema..."
          for i in {1..30}; do
            if curl -s http://api-gateway:3000/health | grep -q "200" || curl -I -s http://api-gateway:3000/ | grep -q "200 OK"; then
              echo "¡API Gateway detectado!"
              break
            fi
            echo "Esperando Gateway (intento $i)..."
            sleep 5
          done

          echo "4. Estabilización final de conexiones internas (RabbitMQ/Java)..."
          sleep 45

          # Ejecutar las pruebas ORIGINALES del Reto 5
          docker run --rm \
            --network retos-microservicios_microservices-network \
            -e BASE_URL=http://api-gateway:3000 \
            -e ADMIN_EMAIL=admin@empresa.com \
            -e ADMIN_PASSWORD=password \
            -e USER_EMAIL=juan@empresa.com \
            -e USER_PASSWORD=MiPass123 \
            --volumes-from $JENKINS_CONTAINER \
            -w "$WORKSPACE/Reto5/e2e-tests" \
            node:20-slim sh -lc "npm install && npm test"
        '''
      }
      post {
        always {
          sh 'docker-compose stop database-empleados database-departamentos notification-db perfiles-db db-auth rabbitmq auth-service perfiles-service notificaciones-service departamentos-service empleados-service api-gateway'
        }
      }
    }
  }
}
