pipeline {
  agent any

  environment {
    IMAGE_NAME = 'reto6-express-service'
    SONAR_HOST_URL = "${env.SONAR_HOST_URL ?: 'http://sonarqube:9000'}"
    JENKINS_CONTAINER = 'retos-microservicios-jenkins-1'
  }

  options {
    skipDefaultCheckout(true)
    disableConcurrentBuilds()
  }

  triggers {
    githubPush()
    pollSCM('* * * * *')
  }

  stages {
    stage('Docker Preflight') {
      steps {
        sh 'docker --version'
        sh 'docker ps'
      }
    }

    stage('Checkout') {
      steps {
        deleteDir()
        checkout scm
      }
    }

    stage('Build') {
      steps {
        sh '''
          docker run --rm \
            --volumes-from $JENKINS_CONTAINER \
            -w "$WORKSPACE/Reto6" \
            node:20-slim sh -lc "[ -f package-lock.json ] || npm install --package-lock-only; npm ci"
        '''
      }
    }

    stage('Test') {
      steps {
        sh '''
          docker run --rm \
            --volumes-from $JENKINS_CONTAINER \
            -w "$WORKSPACE/Reto6" \
            node:20-slim sh -c "npm run test:unit"
        '''
      }
      post {
        always {
          junit testResults: 'Reto6/reports/junit/*.xml', allowEmptyResults: true
          archiveArtifacts artifacts: 'Reto6/coverage/lcov.info', fingerprint: true
        }
      }
    }

    stage('SonarQube') {
      steps {
        withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
          sh '''
            docker run --rm \
              -u root \
              --network retos-microservicios_microservices-network \
              --volumes-from $JENKINS_CONTAINER \
              -e SONAR_HOST_URL=$SONAR_HOST_URL \
              -e SONAR_TOKEN=$SONAR_TOKEN \
              -w "$WORKSPACE/Reto6" \
              sonarsource/sonar-scanner-cli:latest \
              sonar-scanner \
                -Dsonar.projectKey=reto6-express-service \
                -Dsonar.projectName="Reto 6 Express Service" \
                -Dsonar.sources=. \
                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                -Dsonar.host.url=$SONAR_HOST_URL \
                -Dsonar.token=$SONAR_TOKEN \
                -Dsonar.working.directory=.scannerwork
          '''
        }
      }
    }

    stage('Quality Gate') {
      steps {
        withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
          dir('Reto6') {
            sh '''
              set -e
              # Polling for background task completion
              CE_TASK_URL=$(grep ceTaskUrl .scannerwork/report-task.txt | cut -d= -f2-)
              echo "Checking task status at $CE_TASK_URL"
              
              for i in $(seq 1 30); do
                TASK_RESPONSE=$(curl -s -u "$SONAR_TOKEN:" "$CE_TASK_URL")
                STATUS=$(echo "$TASK_RESPONSE" | jq -r '.task.status')
                echo "Task status: $STATUS"
                
                if [ "$STATUS" = "SUCCESS" ]; then
                  ANALYSIS_ID=$(echo "$TASK_RESPONSE" | jq -r '.task.analysisId')
                  break
                fi
                if [ "$STATUS" = "FAILED" ]; then
                  echo "SonarQube analysis failed"
                  exit 1
                fi
                sleep 5
              done

              if [ -z "$ANALYSIS_ID" ]; then
                echo "Timeout waiting for SonarQube analysis"
                exit 1
              fi

              QG_STATUS=$(curl -s -u "$SONAR_TOKEN:" "$SONAR_HOST_URL/api/qualitygates/project_status?analysisId=$ANALYSIS_ID" | jq -r '.projectStatus.status')
              echo "Quality Gate status: $QG_STATUS"
              
              if [ "$QG_STATUS" != "OK" ]; then
                echo "Quality Gate failed: $QG_STATUS"
                exit 1
              fi
            '''
          }
        }
      }
    }

    stage('Package') {
      steps {
        dir('Reto6') {
          sh '''
            docker build -t $IMAGE_NAME:$BUILD_NUMBER -t $IMAGE_NAME:latest .
          '''
        }
      }
    }

    stage('E2E Tests') {
      steps {
        sh '''
          set -e
          INFRA="database-empleados database-departamentos notification-db perfiles-db db-auth rabbitmq"
          SERVICES="auth-service perfiles-service notificaciones-service departamentos-service empleados-service api-gateway"
          VOLUMES="empleados_data departamentos_data notifications_data perfiles_data auth_data"
          
          # Puertos dinámicos para evitar colisiones
          export DB_EMP_PORT=0 DB_DEP_PORT=0 DB_NOT_PORT=0 DB_PER_PORT=0 DB_AUTH_PORT=0
          export EMP_SVC_PORT=0 DEP_SVC_PORT=0 NOT_SVC_PORT=0 PER_SVC_PORT=0 AUTH_SVC_PORT=0
          export GATEWAY_PORT=0 RETO6_PORT=0 RABBIT_PORT=0 RABBIT_MGMT_PORT=0

          echo "Limpando entorno y volumenes para un estado fresco..."
          docker-compose stop $SERVICES $INFRA 2>/dev/null || true
          docker-compose rm -f -v $SERVICES $INFRA 2>/dev/null || true
          
          echo "Levantando infraestructura..."
          docker-compose up -d $INFRA
          
          echo "Esperando a que las bases de datos acepten conexiones..."
          sleep 30
          
          echo "Verificando que las bases de datos estén listas..."
          for i in $(seq 1 40); do
            if docker-compose exec -T database-departamentos pg_isready -U camilo -d departamentos_db >/dev/null 2>&1 && \
               docker-compose exec -T database-empleados pg_isready -U camilo -d empleados_db >/dev/null 2>&1 && \
               docker-compose exec -T notification-db mysqladmin ping -h localhost -uroot -prootpassword >/dev/null 2>&1 && \
               docker-compose exec -T rabbitmq rabbitmq-diagnostics ping >/dev/null 2>&1; then
              echo "✓ Todas las bases de datos están listas"
              break
            fi
            echo "  Intento $i/40: Esperando a las bases de datos..."
            sleep 3
          done

          echo "Levantando microservicios..."
          docker-compose up -d $SERVICES
          
          echo "Dando tiempo para que los servicios se inicialicen completamente (60s)..."
          sleep 60
          
          echo "Verificando salud de cada componente..."
          CHECK_SERVICES="api-gateway:3000 auth-service:3001 empleados-service:8080 departamentos-service:8081 perfiles-service:8085 notificaciones-service:8084"
          
          for svc in $CHECK_SERVICES; do
            NAME=$(echo $svc | cut -d: -f1)
            PORT=$(echo $svc | cut -d: -f2)
            echo "Verificando salud de $NAME en puerto $PORT..."
            READY=0
            for i in $(seq 1 30); do
              if curl -s -f http://$NAME:$PORT/health >/dev/null 2>&1 || curl -s -f http://$NAME:$PORT/ >/dev/null 2>&1; then
                echo "✓ $NAME está OK en intento $i"
                READY=1
                break
              fi
              if [ $i -lt 30 ]; then
                echo "  Intento $i/30: $NAME aún no responde, esperando..."
                sleep 2
              fi
            done
            if [ $READY -eq 0 ]; then
              echo "⚠ ADVERTENCIA: $NAME no reportó salud después de 30 intentos, continuando de todas formas..."
            fi
          done

          echo "Asegurando que el Departamento '1' existe en la BD..."
          for i in $(seq 1 5); do
            if docker-compose exec -T database-departamentos psql -U camilo -d departamentos_db -c "INSERT INTO \\"Departamento\\" (id, nombre, descripcion) VALUES ('1', 'Talento Humano', 'Departamento de recursos humanos') ON CONFLICT DO NOTHING;" 2>/dev/null; then
              echo "✓ Departamento insertado/verificado exitosamente"
              break
            else
              echo "  Intento $i/5: Esperando a que la tabla esté lista..."
              sleep 3
            fi
          done

          echo "Esperando sincronización final de RabbitMQ y servicios (30s)..."
          sleep 30

          echo "Ejecutando pruebas E2E..."
          # Ejecutar las pruebas ORIGINALES del Reto 5
          docker run --rm \
            --network retos-microservicios_microservices-network \
            -e BASE_URL=http://api-gateway:3000 \
            -e ADMIN_EMAIL=admin@empresa.com \
            -e ADMIN_PASSWORD=password \
            -e USER_EMAIL=juan@empresa.com \
            -e USER_PASSWORD=MiPass123 \
            --volumes-from $JENKINS_CONTAINER \
            -w "$WORKSPACE/Reto5/e2e-tests" \
            node:20-slim sh -lc "npm install && npm test"
        '''
      }
      post {
        always {
          sh 'docker-compose stop database-empleados database-departamentos notification-db perfiles-db db-auth rabbitmq auth-service perfiles-service notificaciones-service departamentos-service empleados-service api-gateway 2>/dev/null || true'
        }
      }
    }
  }
}
